rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Analytics — public write (tracking), authenticated read (admin dashboard)
    match /pageviews/{doc} {
      allow create: if true;
      allow read: if request.auth != null;
    }

    match /events/{doc} {
      allow create: if true;
      allow read: if request.auth != null;
    }

    match /visitors/{doc} {
      allow read, write: if true;
    }

    match /analytics/{doc} {
      allow read: if true;
      allow write: if true;
    }

    match /analytics_daily/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // Projects — public read, authenticated write
    match /projects/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Everything else — authenticated only
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
